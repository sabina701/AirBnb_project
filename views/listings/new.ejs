<% layout("/layouts/boilerplate") -%>

<div class="row">
  <div class="col-8 offset-2 mt-3">
    <h3>Create a New Listing</h3>
    <form
      action="/listings"
      method="POST"
      novalidate
      class="needs-validation"
      enctype="multipart/form-data"
    >
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>

        <input
          type="text"
          name="listing[title]"
          placeholder="Enter a catchy title"
          class="form-control"
          required
        />
        <div class="valid-feedback">Title looks good!</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
          type="text"
          name="listing[description]"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Tplease enter a short description</div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label"> Upload Listing Image</label>
        <input
          type="file"
          name="listing[image]"
          placeholder="Enter IMAGE url/link"
          class="form-control"
        />
      </div>

      <div class="row">
        <div class="mb-3 col-md-4 col-sm-12">
          <label for="price" class="form-label">Price</label>
          <input
            name="listing[price]"
            placeholder="1200"
            class="form-control"
            required
          />
          <div class="invalid-feedback">price should be valid</div>
        </div>

        <div class="mb-3 col-md-8 col-sm-12">
          <label for="country" class="form-label">Country</label>
          <input
            type="text"
            name="listing[country]"
            placeholder="Nepal"
            class="form-control"
            required
          />
          <div class="invalid-feedback">country name should be valid</div>
        </div>
      </div>
      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input
          type="text"
          name="listing[location]"
          placeholder="Enter location"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Location should be valid</div>
      </div>

      <button class="btn btn-dark mb-3 mt-3 add-btn">Add</button>
    </form>
  </div>
</div>
